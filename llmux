#!/usr/bin/env bash
set -euo pipefail

SESSION="llmux"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/llmux"
CONFIG_FILE="$CONFIG_DIR/config"

usage() {
  cat <<EOF
llmux — multiplex LLM sessions in tmux

Usage:
  llmux add <name> [directory] [--tool <tool>]  Add a new pane (default tool from config)
  llmux resume [--tool <tool>]                  Pick a past session to resume
  llmux grab <name> [pane]                      Move an existing tmux pane into llmux
  llmux rm [name]                               Remove pane by name (or pick)
  llmux kill                                    Kill the entire llmux session
  llmux ls                                      List active panes
  llmux attach                                  Attach to the llmux session
  llmux refresh                                  Recreate session, drop idle panes
  llmux setup                                   Install deps + configure LLM tools
  llmux help                                    Show this help

Examples:
  llmux add "auth-refactor" ~/code/myproject
  llmux add "bug-hunt" --tool amp
  llmux resume                                  # resume with default tool
  llmux resume --tool claude                    # resume a claude session specifically
  llmux grab "ongoing-debug"
  llmux rm "auth-refactor"
EOF
}

check_deps() {
  local missing=()
  for dep in gum tmux python3; do
    command -v "$dep" &>/dev/null || missing+=("$dep")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing dependencies: ${missing[*]}"
    echo "Run 'llmux setup' to install them."
    exit 1
  fi
}

KNOWN_TOOLS=(amp claude codex aider sgpt llm mods ollama)

load_config() {
  LLMUX_TOOL=""
  LLMUX_TOOL_ARGS=""
  if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
  fi
}

get_tool_args() {
  local tool="$1"
  load_config
  local upper
  upper=$(echo "$tool" | tr '[:lower:]-' '[:upper:]_')
  local var="LLMUX_ARGS_${upper}"
  local args
  eval "args=\${$var:-}"
  if [[ -z "$args" && "$tool" == "${LLMUX_TOOL:-}" ]]; then
    args="${LLMUX_TOOL_ARGS:-}"
  fi
  echo "$args"
}

build_tool_cmd() {
  local tool="$1"
  local args
  args="$(get_tool_args "$tool")"
  echo "$tool${args:+ $args}"
}

launch_tool_in_pane() {
  local pane_target="$1"
  local tool="${2:-}"
  local session_name="${3:-}"

  if [[ -z "$tool" ]]; then
    load_config
    tool="${LLMUX_TOOL:-}"
  fi

  if [[ -n "$tool" ]]; then
    tmux set-option -p -t "$pane_target" @llmux_tool "$tool"
    local tool_cmd
    tool_cmd="$(build_tool_cmd "$tool")"
    local launch_cmd="unset CLAUDECODE CLAUDE_CODE_SESSION; "
    if [[ -n "$session_name" && "$tool" == "amp" ]]; then
      local args
      args="$(get_tool_args "$tool")"
      launch_cmd+="THREAD_ID=\$(amp threads new --no-color 2>/dev/null) && amp threads rename \"\$THREAD_ID\" $(printf '%q' "$session_name") 2>/dev/null; amp${args:+ $args} threads continue \"\$THREAD_ID\""
    else
      launch_cmd+="$tool_cmd"
    fi
    tmux send-keys -t "$pane_target" "$launch_cmd" Enter
    if [[ -n "$session_name" && "$tool" == "claude" ]]; then
      # Wait for Claude to start, then send /rename
      (sleep 3 && tmux send-keys -t "$pane_target" "/rename $(printf '%q' "$session_name")" Enter) &
      disown
    fi
  fi
}

resume_tool_in_pane() {
  local pane_target="$1"
  local tool="$2"

  local tool_cmd
  tool_cmd="$(build_tool_cmd "$tool")"
  local resume_cmd="unset CLAUDECODE CLAUDE_CODE_SESSION; "
  case "$tool" in
    claude) resume_cmd+="$tool_cmd --continue" ;;
    codex)  resume_cmd+="$tool_cmd resume --last" ;;
    amp)    resume_cmd+="$tool_cmd" ;;
    *)      resume_cmd+="$tool_cmd" ;;
  esac
  tmux set-option -p -t "$pane_target" @llmux_tool "$tool"
  tmux send-keys -t "$pane_target" "$resume_cmd" Enter
}

is_default_title() {
  local title="$1"
  [[ -z "$title" || "$title" == "bash" || "$title" == "zsh" || "$title" == "$(hostname)" || "$title" == "$(hostname -s 2>/dev/null)" ]]
}

ensure_session() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux new-session -d -s "$SESSION" -x - -y -
    # Enable pane titles in the border
    tmux set-option -t "$SESSION" pane-border-status top
    tmux set-option -t "$SESSION" pane-border-format ' #{?#{@llmux_name},#{@llmux_name},#{pane_title}} [#{pane_current_path}] '
    # Style the borders for clarity
    tmux set-option -t "$SESSION" pane-border-style 'fg=colour240'
    tmux set-option -t "$SESSION" pane-active-border-style 'fg=colour39,bold'
    # Enable mouse for scrolling and pane selection (toggle with prefix + m)
    tmux set-option -t "$SESSION" mouse on
    tmux bind-key -T prefix m set-option mouse
    tmux set-option -t "$SESSION" status-right "#{?mouse, [mouse] ,} %H:%M "
    # Allow mouse wheel to scroll in non-alternate-screen panes (plain shells)
    tmux set-option -t "$SESSION" terminal-overrides 'xterm*:smcup@:rmcup@'
    # Copy mouse selections to system clipboard
    tmux set-option -s copy-command "pbcopy"
    # Mark the initial pane as the dedicated terminal (top horizontal slice)
    tmux set-option -p -t "$SESSION" @llmux_terminal "1"
    tmux set-option -p -t "$SESSION" @llmux_name "terminal"
    tmux select-pane -t "$SESSION" -T "terminal"
    # Auto re-layout when a pane exits (e.g. user exits a tool manually)
    tmux set-hook -t "$SESSION" pane-exited "select-layout main-horizontal"
    INITIAL_PANE=1
  fi
}

# Get the pane_id of the dedicated terminal pane
get_terminal_pane() {
  tmux list-panes -t "$SESSION" -F '#{pane_id}|#{@llmux_terminal}' 2>/dev/null \
    | grep '|1$' | head -1 | cut -d'|' -f1
}

# Re-layout: terminal pane as top horizontal slice, LLM panes tiled below.
# Uses a main-horizontal-style layout with the terminal pane on top occupying
# ~25% of the window height.
apply_layout() {
  local term_pane
  term_pane=$(get_terminal_pane)
  [[ -z "$term_pane" ]] && return

  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$pane_count" -le 1 ]]; then
    return
  fi

  # Ensure terminal pane is first (index 0) so main-horizontal puts it on top
  local first_pane
  first_pane=$(tmux list-panes -t "$SESSION" -F '#{pane_id}' | head -1)
  if [[ "$first_pane" != "$term_pane" ]]; then
    tmux swap-pane -s "$term_pane" -t "$first_pane"
  fi

  # Use main-horizontal layout: top pane is the "main" pane, bottom is tiled
  local win_height
  win_height=$(tmux display-message -t "$SESSION" -p '#{window_height}')
  local main_height=$(( win_height * 25 / 100 ))
  [[ "$main_height" -lt 10 ]] && main_height=10
  tmux set-option -t "$SESSION" main-pane-height "$main_height"
  tmux select-layout -t "$SESSION" main-horizontal
}

attach_to_pane() {
  local name="$1"
  # Select the pane by llmux name
  local pane_id
  pane_id=$(tmux list-panes -t "$SESSION" -F '#{pane_id}|#{@llmux_name}' | grep "|${name}$" | head -1 | cut -d'|' -f1)
  if [[ -n "$pane_id" ]]; then
    tmux select-pane -t "$pane_id"
  fi
  # Attach or switch
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach-session -t "$SESSION"
  fi
}

cmd_add() {
  local name="" dir="" tool_override=""

  # Parse args: name [directory] [--tool <tool>]
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tool) tool_override="${2:?--tool requires a value}"; shift 2 ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$dir" ]]; then
          dir="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Usage: llmux add <name> [directory] [--tool <tool>]"; exit 1; }
  dir="${dir:-$(pwd)}"
  dir="$(cd "$dir" && pwd)"

  ensure_session

  if tmux list-panes -t "$SESSION" -F '#{@llmux_name}' 2>/dev/null | grep -qxF "$name"; then
    echo "Error: pane '$name' already exists"
    exit 1
  fi

  # Always split a new pane for the LLM tool (terminal pane stays on top)
  local new_pane
  new_pane=$(tmux split-window -t "$SESSION" -v -c "$dir" -P -F '#{pane_id}')
  tmux select-pane -t "$new_pane" -T "$name"
  tmux set-option -p -t "$new_pane" @llmux_name "$name"
  apply_layout
  launch_tool_in_pane "$new_pane" "$tool_override" "$name"
  echo "Created pane '$name' in $dir"
  attach_to_pane "$name"
}

cmd_rm() {
  local name="${1:-}"

  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Error: no llmux session running"
    exit 1
  fi

  # If no name given, show a picker (exclude the terminal pane)
  if [[ -z "$name" ]]; then
    local names=()
    while IFS= read -r line; do
      local n is_term
      n=$(echo "$line" | cut -d'|' -f1)
      is_term=$(echo "$line" | cut -d'|' -f2)
      [[ -z "$n" ]] && continue
      [[ "$is_term" == "1" ]] && continue
      names+=("$n")
    done < <(tmux list-panes -t "$SESSION" -F '#{@llmux_name}|#{@llmux_terminal}')

    if [[ ${#names[@]} -eq 0 ]]; then
      echo "No named panes to remove."
      exit 0
    fi

    name=$(printf '%s\n' "${names[@]}" | gum filter \
      --header "Remove which pane?" \
      --indicator "▸" \
      --indicator.foreground "212" \
      --match.foreground "212" \
      --header.foreground "99" \
      --prompt.foreground "39")
    [[ -z "$name" ]] && exit 0
  fi

  # Prevent removing the terminal pane
  if [[ "$name" == "terminal" ]]; then
    local term_pane
    term_pane=$(get_terminal_pane)
    if [[ -n "$term_pane" ]]; then
      echo "Error: cannot remove the terminal pane"
      exit 1
    fi
  fi

  # Find the pane with this llmux name
  local target_pane=""
  while IFS= read -r line; do
    local pane_id pane_name
    pane_id=$(echo "$line" | cut -d'|' -f1)
    pane_name=$(echo "$line" | cut -d'|' -f2)
    if [[ "$pane_name" == "$name" ]]; then
      target_pane="$pane_id"
      break
    fi
  done < <(tmux list-panes -t "$SESSION" -F '#{pane_id}|#{@llmux_name}')

  if [[ -z "$target_pane" ]]; then
    echo "Error: no pane named '$name'"
    exit 1
  fi

  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" | wc -l | tr -d ' ')

  if [[ "$pane_count" -le 2 ]]; then
    # Only terminal + this pane left — kill just the LLM pane, keep terminal
    tmux kill-pane -t "$target_pane"
    echo "Removed pane '$name'"
  else
    tmux kill-pane -t "$target_pane"
    apply_layout
    echo "Removed pane '$name'"
  fi
}

cmd_ls() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No llmux session running"
    exit 0
  fi

  printf "%-4s  %-30s  %-6s  %s\n" "IDX" "NAME" "TYPE" "DIRECTORY"
  printf "%-4s  %-30s  %-6s  %s\n" "---" "----" "----" "---------"
  local idx=0
  while IFS= read -r line; do
    local pane_name pane_path is_term pane_type
    pane_name=$(echo "$line" | cut -d'|' -f1)
    pane_path=$(echo "$line" | cut -d'|' -f2)
    is_term=$(echo "$line" | cut -d'|' -f3)
    [[ -z "$pane_name" ]] && pane_name="(unnamed)"
    pane_type="llm"
    [[ "$is_term" == "1" ]] && pane_type="term"
    printf "%-4s  %-30s  %-6s  %s\n" "$idx" "$pane_name" "$pane_type" "$pane_path"
    ((idx++))
  done < <(tmux list-panes -t "$SESSION" -F '#{@llmux_name}|#{pane_current_path}|#{@llmux_terminal}')
}

cmd_attach() {
  ensure_session
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach-session -t "$SESSION"
  fi
}

cmd_setup() {
  # --- Install dependencies ---
  local deps=(gum tmux python3)
  local missing=()
  for dep in "${deps[@]}"; do
    command -v "$dep" &>/dev/null || missing+=("$dep")
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Installing missing dependencies: ${missing[*]}"
    if command -v brew &>/dev/null; then
      local brew_pkgs=()
      for dep in "${missing[@]}"; do
        case "$dep" in
          python3) brew_pkgs+=("python") ;;
          *)       brew_pkgs+=("$dep") ;;
        esac
      done
      brew install "${brew_pkgs[@]}"
    else
      echo "Error: Homebrew not found. Install manually: ${missing[*]}"
      exit 1
    fi
    echo ""
  fi

  echo "✓ All dependencies installed"
  echo ""

  # --- Find available LLM tools ---
  local found_tools=()
  for tool in "${KNOWN_TOOLS[@]}"; do
    command -v "$tool" &>/dev/null && found_tools+=("$tool")
  done

  if [[ ${#found_tools[@]} -eq 0 ]]; then
    echo "No known LLM tools found on PATH."
    exit 0
  fi

  # --- Configure args for each found tool ---
  mkdir -p "$CONFIG_DIR"
  : > "$CONFIG_FILE"

  for tool in "${found_tools[@]}"; do
    local default_args=""
    case "$tool" in
      claude) default_args="--dangerously-skip-permissions" ;;
      codex)  default_args="--full-auto" ;;
    esac
    local args
    if [[ -n "$default_args" ]]; then
      read -rp "Args for $tool [$default_args]: " args
      [[ -z "$args" ]] && args="$default_args"
    else
      read -rp "Args for $tool (enter to skip): " args
    fi
    local upper
    upper=$(echo "$tool" | tr '[:lower:]-' '[:upper:]_')
    echo "LLMUX_ARGS_${upper}=\"${args}\"" >> "$CONFIG_FILE"
    if [[ -n "$args" ]]; then
      echo "  $tool: $args"
    else
      echo "  $tool: (no args)"
    fi
  done

  # --- Pick default tool ---
  echo ""
  local selected
  selected=$(printf '%s\n' "(none)" "${found_tools[@]}" | gum choose --header "Select DEFAULT LLM tool")
  [[ "$selected" == "(none)" ]] && selected=""

  # Write default at the top of config
  local tmp
  tmp=$(mktemp)
  echo "LLMUX_TOOL=\"$selected\"" > "$tmp"
  cat "$CONFIG_FILE" >> "$tmp"
  mv "$tmp" "$CONFIG_FILE"

  echo ""
  if [[ -n "$selected" ]]; then
    echo "✓ Default tool: $selected"
  else
    echo "✓ No default tool (shell only)"
  fi
  echo "  Saved to $CONFIG_FILE"
}

harvest_claude_sessions() {
  python3 << 'PYEOF'
import json, os, glob, time

def relative_time(mtime):
    delta = int(time.time() - mtime)
    if delta < 60:
        return f"{delta}s ago"
    elif delta < 3600:
        return f"{delta // 60}m ago"
    elif delta < 86400:
        return f"{delta // 3600}h ago"
    else:
        days = delta // 86400
        return f"{days}d ago"

def decode_project_path(encoded):
    """Decode Claude's project dir encoding by finding the real path on disk.
    Tries /, ., and - as separators with backtracking to find a valid path."""
    parts = encoded.lstrip("-").split("-")

    def resolve(idx, current):
        if idx == len(parts):
            return current
        part = parts[idx]
        seps = ["/"] if not current else ["/", ".", "-"]
        for sep in seps:
            candidate = current + sep + part
            result = resolve(idx + 1, candidate)
            if result and os.path.exists(result):
                return result
        return current + "/" + part if idx == len(parts) - 1 else None

    result = resolve(0, "")
    return result if result and os.path.exists(result) else "/" + "/".join(parts)

projects_dir = os.path.expanduser("~/.claude/projects")
if not os.path.isdir(projects_dir):
    exit(0)

home = os.path.expanduser("~")
for jsonl in sorted(glob.glob(f"{projects_dir}/*/*.jsonl"), key=os.path.getmtime, reverse=True)[:20]:
    project = os.path.basename(os.path.dirname(jsonl))
    session_id = os.path.basename(jsonl).replace(".jsonl", "")
    mtime = os.path.getmtime(jsonl)

    proj_path = decode_project_path(project)

    # Find first real user message as summary
    summary = ""
    with open(jsonl) as f:
        for line in f:
            try:
                msg = json.loads(line.strip())
                if msg.get("type") != "user":
                    continue
                content = msg.get("message", {}).get("content", "")
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    text = next((b["text"] for b in content if isinstance(b, dict) and b.get("type") == "text"), "")
                else:
                    continue
                if text and not text.startswith("<local-command") and not text.startswith("<command-name>"):
                    summary = text[:80].replace("\n", " ").strip()
                    break
            except:
                pass

    ts = relative_time(mtime)
    # Output pipe-delimited: session_id|project_path|timestamp|summary
    print(f"{session_id}|{proj_path}|{ts}|{summary or '(empty session)'}")
PYEOF
}

harvest_amp_sessions() {
  amp threads list 2>/dev/null | tail -n +3 | while IFS= read -r line; do
    # Parse the table output: Title, Last Updated, Visibility, Messages, Thread ID
    # The format is column-aligned, thread ID is the last field
    local thread_id title updated
    thread_id=$(echo "$line" | grep -oE 'T-[0-9a-f-]+' | head -1)
    [[ -z "$thread_id" ]] && continue
    # Extract title (everything before the first date-like pattern or time-ago)
    title=$(echo "$line" | sed -E 's/[[:space:]]+(([0-9]+[smhd]|[0-9]+ (seconds?|minutes?|hours?|days?|weeks?|months?)) ago|[0-9]{4}-[0-9]{2}-[0-9]{2}).*//' | sed 's/[[:space:]]*$//')
    updated=$(echo "$line" | grep -oE '([0-9]+[smhd]|[0-9]+ (seconds?|minutes?|hours?|days?|weeks?|months?)) ago' | head -1)
    # Output: session_id|directory|timestamp|summary
    echo "${thread_id}|$(pwd)|${updated:-unknown}|${title}"
  done
}

harvest_codex_sessions() {
  local db="$HOME/.codex/state_5.sqlite"
  [[ -f "$db" ]] || return
  sqlite3 -separator '|' "$db" \
    "SELECT id, cwd, updated_at, REPLACE(SUBSTR(title, 1, 80), CHAR(10), ' ')
     FROM threads WHERE archived = 0
     ORDER BY updated_at DESC LIMIT 50" 2>/dev/null | while IFS='|' read -r sid cwd ts title; do
    [[ -z "$sid" ]] && continue
    local rel_ts
    rel_ts=$(python3 -c "
import time
diff = int(time.time()) - int('$ts')
if diff < 60: print(f'{diff}s ago')
elif diff < 3600: print(f'{diff//60}m ago')
elif diff < 86400: print(f'{diff//3600}h ago')
else: print(f'{diff//86400}d ago')
" 2>/dev/null)
    echo "${sid}|${cwd}|${rel_ts:-unknown}|${title}"
  done
}

cmd_resume() {
  local tool_override=""

  # Parse args: [--tool <tool>]
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tool) tool_override="${2:?--tool requires a value}"; shift 2 ;;
      *) shift ;;
    esac
  done

  # Determine which tool to browse
  local tool="$tool_override"
  if [[ -z "$tool" ]]; then
    load_config
    # Find all resumable tools on the system
    local resumable=()
    for t in claude amp codex; do
      command -v "$t" &>/dev/null && resumable+=("$t")
    done

    if [[ ${#resumable[@]} -eq 0 ]]; then
      echo "No resumable tools found (need claude, amp, or codex)."
      exit 1
    elif [[ ${#resumable[@]} -eq 1 ]]; then
      tool="${resumable[0]}"
    else
      tool=$(printf '%s\n' "${resumable[@]}" | gum choose --header "Which tool's sessions?")
      [[ -z "$tool" ]] && exit 0
    fi
  fi

  # Harvest sessions
  local raw_lines=()
  local display_lines=()

  case "$tool" in
    claude)
      while IFS='|' read -r sid dir ts summary; do
        [[ -z "$sid" ]] && continue
        raw_lines+=("$sid|$dir|$ts|$summary")
        local short_dir="${dir/#$HOME/~}"
        display_lines+=("$(printf '%-10s │ %-50s │ %s' "$ts" "${summary:0:50}" "$short_dir")")
      done < <(harvest_claude_sessions)
      ;;
    amp)
      while IFS='|' read -r sid dir ts summary; do
        [[ -z "$sid" ]] && continue
        raw_lines+=("$sid|$dir|$ts|$summary")
        local short_dir="${dir/#$HOME/~}"
        display_lines+=("$(printf '%-10s │ %-50s │ %s' "${ts:-?}" "${summary:0:50}" "$short_dir")")
      done < <(harvest_amp_sessions)
      ;;
    codex)
      while IFS='|' read -r sid dir ts summary; do
        [[ -z "$sid" ]] && continue
        raw_lines+=("$sid|$dir|$ts|$summary")
        local short_dir="${dir/#$HOME/~}"
        display_lines+=("$(printf '%-10s │ %-50s │ %s' "${ts:-?}" "${summary:0:50}" "$short_dir")")
      done < <(harvest_codex_sessions)
      ;;
    *)
      echo "Resume not supported for '$tool'. Supported: claude, amp, codex"
      exit 1
      ;;
  esac

  if [[ ${#raw_lines[@]} -eq 0 ]]; then
    echo "No past sessions found."
    exit 0
  fi

  # Pick a session
  local selected_line
  selected_line=$(printf '%s\n' "${display_lines[@]}" | gum filter \
    --header "Resume a $tool session" \
    --indicator "▸" \
    --indicator.foreground "212" \
    --text.foreground "245" \
    --match.foreground "212" \
    --header.foreground "99" \
    --prompt.foreground "39" \
    --cursor-text.foreground "white")

  [[ -z "$selected_line" ]] && exit 0

  # Find the matching raw line
  local match_idx=-1
  for i in "${!display_lines[@]}"; do
    if [[ "${display_lines[$i]}" == "$selected_line" ]]; then
      match_idx=$i
      break
    fi
  done

  if [[ "$match_idx" -lt 0 ]]; then
    echo "Error: could not match selection"
    exit 1
  fi

  local selected_id selected_dir selected_summary
  selected_id=$(echo "${raw_lines[$match_idx]}" | cut -d'|' -f1)
  selected_dir=$(echo "${raw_lines[$match_idx]}" | cut -d'|' -f2)
  selected_summary=$(echo "${raw_lines[$match_idx]}" | cut -d'|' -f4)

  # Prompt for pane name (default to summary)
  local default_name="${selected_summary:0:40}"
  [[ -z "$default_name" ]] && default_name="$selected_id"
  local pane_name
  read -rp "Pane name [$default_name]: " pane_name
  [[ -z "$pane_name" ]] && pane_name="$default_name"

  # Build resume command with per-tool args
  local tool_cmd
  tool_cmd="$(build_tool_cmd "$tool")"
  local resume_cmd=""
  case "$tool" in
    claude) resume_cmd="$tool_cmd --resume $selected_id" ;;
    amp)    resume_cmd="$tool_cmd threads continue $selected_id" ;;
    codex)  resume_cmd="$tool_cmd resume $selected_id" ;;
  esac

  # Create the pane and launch
  ensure_session

  local new_pane
  new_pane=$(tmux split-window -t "$SESSION" -v -c "$selected_dir" -P -F '#{pane_id}')
  tmux select-pane -t "$new_pane" -T "$pane_name"
  tmux set-option -p -t "$new_pane" @llmux_name "$pane_name"
  apply_layout
  tmux send-keys -t "$new_pane" "unset CLAUDECODE CLAUDE_CODE_SESSION; $resume_cmd" Enter
  echo "✓ Resuming as '$pane_name'"
}

cmd_grab() {
  local name="${1:?Usage: llmux grab <name> [source-pane]}"
  local source="${2:-}"

  ensure_session

  # Check if a pane with this name already exists
  if tmux list-panes -t "$SESSION" -F '#{@llmux_name}' 2>/dev/null | grep -qxF "$name"; then
    echo "Error: pane '$name' already exists"
    exit 1
  fi

  # If no source given, show available panes to pick from
  if [[ -z "$source" ]]; then
    echo "Available tmux panes (excluding llmux):"
    echo ""
    local panes=()
    local idx=1
    while IFS= read -r line; do
      local pane_target pane_title pane_cmd pane_path
      pane_target=$(echo "$line" | cut -d'|' -f1)
      pane_title=$(echo "$line" | cut -d'|' -f2)
      pane_cmd=$(echo "$line" | cut -d'|' -f3)
      pane_path=$(echo "$line" | cut -d'|' -f4)
      # Skip panes in the llmux session
      [[ "$pane_target" == "$SESSION:"* ]] && continue
      panes+=("$pane_target")
      printf "  %d) %s  [%s]  (%s)\n" "$idx" "$pane_target" "$pane_cmd" "$pane_path"
      ((idx++))
    done < <(tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}|#{pane_title}|#{pane_current_command}|#{pane_current_path}')

    if [[ ${#panes[@]} -eq 0 ]]; then
      echo "  No other panes found."
      exit 0
    fi

    echo ""
    local choice
    read -rp "Select pane to grab [1]: " choice
    choice="${choice:-1}"
    if [[ "$choice" -lt 1 || "$choice" -gt ${#panes[@]} ]]; then
      echo "Invalid choice"
      exit 1
    fi
    source="${panes[$((choice - 1))]}"
  fi

  # Join the source pane into llmux (terminal pane stays on top)
  tmux join-pane -s "$source" -t "$SESSION" -v
  tmux select-pane -t "$SESSION" -T "$name"
  tmux set-option -p -t "$SESSION" @llmux_name "$name"
  apply_layout
  echo "Grabbed pane '$source' as '$name'"
}

cmd_kill() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No llmux session running"
    exit 0
  fi
  tmux kill-session -t "$SESSION"
  echo "Killed llmux session"
}

cmd_refresh() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No llmux session running"
    exit 0
  fi

  # Snapshot current panes: llmux name, directory, tool, terminal flag
  local pane_data=()
  while IFS='|' read -r name dir tool is_term; do
    pane_data+=("$name|$dir|$tool|$is_term")
  done < <(tmux list-panes -t "$SESSION" -F '#{@llmux_name}|#{pane_current_path}|#{@llmux_tool}|#{@llmux_terminal}')

  # Kill the old session
  tmux kill-session -t "$SESSION"

  # Filter to named non-terminal panes only
  local active=()
  local skipped=()
  for entry in "${pane_data[@]}"; do
    local name dir tool is_term
    name=$(echo "$entry" | cut -d'|' -f1)
    dir=$(echo "$entry" | cut -d'|' -f2)
    tool=$(echo "$entry" | cut -d'|' -f3)
    is_term=$(echo "$entry" | cut -d'|' -f4)

    # Skip the terminal pane — it will be recreated by ensure_session
    [[ "$is_term" == "1" ]] && continue

    if [[ -z "$name" ]]; then
      skipped+=("(unnamed shell in $dir)")
      continue
    fi

    active+=("$name|$dir|$tool")
  done

  # Recreate session (this creates the terminal pane)
  ensure_session

  if [[ ${#active[@]} -eq 0 ]]; then
    echo "No named panes to restore."
    return
  fi

  # Recreate each LLM pane below the terminal
  for entry in "${active[@]}"; do
    local name dir tool
    name=$(echo "$entry" | cut -d'|' -f1)
    dir=$(echo "$entry" | cut -d'|' -f2)
    tool=$(echo "$entry" | cut -d'|' -f3)

    local new_pane
    new_pane=$(tmux split-window -t "$SESSION" -v -c "$dir" -P -F '#{pane_id}')
    tmux select-pane -t "$new_pane" -T "$name"
    tmux set-option -p -t "$new_pane" @llmux_name "$name"
    if [[ -z "$tool" ]]; then
      load_config
      tool="${LLMUX_TOOL:-}"
    fi
    if [[ -n "$tool" ]]; then
      resume_tool_in_pane "$new_pane" "$tool"
    fi
  done

  apply_layout

  echo ""
  echo "✓ Restored ${#active[@]} pane(s)"
  for entry in "${active[@]}"; do
    echo "  + $(echo "$entry" | cut -d'|' -f1)"
  done
  if [[ ${#skipped[@]} -gt 0 ]]; then
    echo "  Dropped ${#skipped[@]} idle pane(s)"
  fi
}

# --- Main ---
command="${1:-help}"
shift || true

# setup and help don't need deps; everything else does
case "$command" in
  setup|help) ;;
  *)          check_deps ;;
esac

case "$command" in
  add)     cmd_add "$@" ;;
  resume)  cmd_resume "$@" ;;
  grab)    cmd_grab "$@" ;;
  rm)      cmd_rm "$@" ;;
  ls)      cmd_ls "$@" ;;
  attach)  cmd_attach "$@" ;;
  refresh) cmd_refresh "$@" ;;
  kill)    cmd_kill "$@" ;;
  setup)   cmd_setup "$@" ;;
  help)   usage ;;
  *)      echo "Unknown command: $command"; usage; exit 1 ;;
esac

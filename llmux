#!/usr/bin/env bash
set -euo pipefail

SESSION="llmux"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/llmux"
CONFIG_FILE="$CONFIG_DIR/config"

usage() {
  cat <<EOF
llmux — multiplex LLM sessions in tmux

Usage:
  llmux add <name> [directory]   Add a new pane titled <name> (default dir: cwd)
  llmux resume [name]            Pick a past session to resume in a new pane
  llmux grab <name> [pane]       Move an existing tmux pane into llmux
  llmux rm <name>                Remove pane by name
  llmux ls                       List active panes
  llmux attach                   Attach to the llmux session
  llmux setup                    Detect LLM tools and pick a default
  llmux help                     Show this help

Examples:
  llmux add "auth-refactor" ~/code/myproject
  llmux add "bug-investigation"
  llmux resume                                     # pick a past session to resume
  llmux resume "my-label"                           # resume with a custom pane name
  llmux grab "ongoing-debug"                        # grab current pane
  llmux grab "my-session" mysession:0.1             # grab specific pane
  llmux rm "auth-refactor"
EOF
}

get_tool_cmd() {
  if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
    local cmd="${LLMUX_TOOL:-}"
    local args="${LLMUX_TOOL_ARGS:-}"
    if [[ -n "$cmd" ]]; then
      echo "$cmd${args:+ $args}"
    fi
  fi
}

launch_tool() {
  local pane_target="$1"
  local tool_cmd
  tool_cmd="$(get_tool_cmd)"
  if [[ -n "$tool_cmd" ]]; then
    # Unset env vars that cause nesting detection issues (e.g. Claude Code)
    tmux send-keys -t "$pane_target" "unset CLAUDECODE CLAUDE_CODE_SESSION; $tool_cmd" Enter
  fi
}

ensure_session() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux new-session -d -s "$SESSION" -x - -y -
    # Enable pane titles in the border
    tmux set-option -t "$SESSION" pane-border-status top
    tmux set-option -t "$SESSION" pane-border-format ' #{pane_title} [#{pane_current_path}] '
    # Style the borders for clarity
    tmux set-option -t "$SESSION" pane-border-style 'fg=colour240'
    tmux set-option -t "$SESSION" pane-active-border-style 'fg=colour39,bold'
    # Kill the initial empty pane marker — we'll track it
    INITIAL_PANE=1
  fi
}

cmd_add() {
  local name="${1:?Usage: llmux add <name> [directory]}"
  local dir="${2:-$(pwd)}"
  dir="$(cd "$dir" && pwd)" # resolve to absolute path

  ensure_session

  # Check if a pane with this name already exists
  if tmux list-panes -t "$SESSION" -F '#{pane_title}' 2>/dev/null | grep -qxF "$name"; then
    echo "Error: pane '$name' already exists"
    exit 1
  fi

  # Count existing panes
  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    # First pane: check if the only pane is the default untitled one
    local first_title
    first_title=$(tmux list-panes -t "$SESSION" -F '#{pane_title}' | head -1)
    if [[ -z "$first_title" || "$first_title" == "bash" || "$first_title" == "zsh" ]]; then
      # Reuse the initial empty pane
      tmux send-keys -t "$SESSION" "cd '$dir'" Enter
      tmux select-pane -t "$SESSION" -T "$name"
      tmux send-keys -t "$SESSION" "clear" Enter
      launch_tool "$SESSION"
      echo "Created pane '$name' in $dir"
      return
    fi
  fi

  # Split and set up the new pane
  tmux split-window -t "$SESSION" -c "$dir"
  tmux select-pane -t "$SESSION" -T "$name"
  tmux select-layout -t "$SESSION" tiled
  launch_tool "$SESSION"
  echo "Created pane '$name' in $dir"
}

cmd_rm() {
  local name="${1:?Usage: llmux rm <name>}"

  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Error: no llmux session running"
    exit 1
  fi

  # Find the pane with this title
  local target_pane=""
  while IFS= read -r line; do
    local pane_id pane_title
    pane_id=$(echo "$line" | cut -d'|' -f1)
    pane_title=$(echo "$line" | cut -d'|' -f2)
    if [[ "$pane_title" == "$name" ]]; then
      target_pane="$pane_id"
      break
    fi
  done < <(tmux list-panes -t "$SESSION" -F '#{pane_id}|#{pane_title}')

  if [[ -z "$target_pane" ]]; then
    echo "Error: no pane named '$name'"
    exit 1
  fi

  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    # Last pane — kill the whole session
    tmux kill-session -t "$SESSION"
    echo "Removed pane '$name' (session ended)"
  else
    tmux kill-pane -t "$target_pane"
    tmux select-layout -t "$SESSION" tiled
    echo "Removed pane '$name'"
  fi
}

cmd_ls() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No llmux session running"
    exit 0
  fi

  printf "%-4s  %-30s  %s\n" "IDX" "NAME" "DIRECTORY"
  printf "%-4s  %-30s  %s\n" "---" "----" "---------"
  local idx=0
  while IFS= read -r line; do
    local pane_title pane_path
    pane_title=$(echo "$line" | cut -d'|' -f1)
    pane_path=$(echo "$line" | cut -d'|' -f2)
    printf "%-4s  %-30s  %s\n" "$idx" "$pane_title" "$pane_path"
    ((idx++))
  done < <(tmux list-panes -t "$SESSION" -F '#{pane_title}|#{pane_current_path}')
}

cmd_attach() {
  ensure_session
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach-session -t "$SESSION"
  fi
}

cmd_setup() {
  # Known LLM CLI tools to look for
  local known_tools=(amp claude aider sgpt llm mods ollama)
  local found_tools=()

  echo "Scanning for LLM CLI tools..."
  echo ""

  for tool in "${known_tools[@]}"; do
    if command -v "$tool" &>/dev/null; then
      local tool_path
      tool_path="$(command -v "$tool")"
      found_tools+=("$tool")
      echo "  ✓ $tool ($tool_path)"
    fi
  done

  if [[ ${#found_tools[@]} -eq 0 ]]; then
    echo "  No known LLM tools found on PATH."
    echo ""
    echo "You can manually set a tool:"
    echo "  mkdir -p '$CONFIG_DIR' && echo 'LLMUX_TOOL=\"your-command\"' > '$CONFIG_FILE'"
    exit 0
  fi

  echo ""
  echo "Select a default tool to launch in new panes:"
  echo ""
  local i=1
  for tool in "${found_tools[@]}"; do
    echo "  $i) $tool"
    ((i++))
  done
  echo "  0) none (just open a shell)"
  echo ""

  local choice
  read -rp "Choice [1]: " choice
  choice="${choice:-1}"

  if [[ "$choice" == "0" ]]; then
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<'CONF'
LLMUX_TOOL=""
LLMUX_TOOL_ARGS=""
CONF
    echo ""
    echo "Configured: no auto-launch (shell only)"
  elif [[ "$choice" -ge 1 && "$choice" -le ${#found_tools[@]} ]]; then
    local selected="${found_tools[$((choice - 1))]}"
    echo ""
    local args=""
    read -rp "Startup args for $selected (e.g. --dangerously-skip-permissions): " args
    mkdir -p "$CONFIG_DIR"
    cat > "$CONFIG_FILE" <<CONF
LLMUX_TOOL="$selected"
LLMUX_TOOL_ARGS="$args"
CONF
    echo ""
    if [[ -n "$args" ]]; then
      echo "Configured: $selected $args"
    else
      echo "Configured: $selected (no extra args)"
    fi
  else
    echo "Invalid choice"
    exit 1
  fi

  echo "Config saved to $CONFIG_FILE"
}

harvest_claude_sessions() {
  python3 << 'PYEOF'
import json, os, glob, time

projects_dir = os.path.expanduser("~/.claude/projects")
if not os.path.isdir(projects_dir):
    exit(0)

sessions = []
for jsonl in sorted(glob.glob(f"{projects_dir}/*/*.jsonl"), key=os.path.getmtime, reverse=True)[:20]:
    project = os.path.basename(os.path.dirname(jsonl))
    session_id = os.path.basename(jsonl).replace(".jsonl", "")
    mtime = os.path.getmtime(jsonl)

    # Decode project path: leading dash + dashes as /
    proj_path = "/" + project.lstrip("-").replace("-", "/")

    # Find first real user message as summary
    summary = ""
    with open(jsonl) as f:
        for line in f:
            try:
                msg = json.loads(line.strip())
                if msg.get("type") != "user":
                    continue
                content = msg.get("message", {}).get("content", "")
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    text = next((b["text"] for b in content if isinstance(b, dict) and b.get("type") == "text"), "")
                else:
                    continue
                if text and not text.startswith("<local-command") and not text.startswith("<command-name>"):
                    summary = text[:80].replace("\n", " ").strip()
                    break
            except:
                pass

    ts = time.strftime("%Y-%m-%d %H:%M", time.localtime(mtime))
    # Output pipe-delimited: session_id|project_path|timestamp|summary
    print(f"{session_id}|{proj_path}|{ts}|{summary or '(empty session)'}")
PYEOF
}

harvest_amp_sessions() {
  amp threads list 2>/dev/null | tail -n +3 | while IFS= read -r line; do
    # Parse the table output: Title, Last Updated, Visibility, Messages, Thread ID
    # The format is column-aligned, thread ID is the last field
    local thread_id title updated
    thread_id=$(echo "$line" | grep -oE 'T-[0-9a-f-]+' | head -1)
    [[ -z "$thread_id" ]] && continue
    # Extract title (everything before the first date-like pattern or time-ago)
    title=$(echo "$line" | sed -E 's/[[:space:]]+(([0-9]+[smhd]|[0-9]+ (seconds?|minutes?|hours?|days?|weeks?|months?)) ago|[0-9]{4}-[0-9]{2}-[0-9]{2}).*//' | sed 's/[[:space:]]*$//')
    updated=$(echo "$line" | grep -oE '([0-9]+[smhd]|[0-9]+ (seconds?|minutes?|hours?|days?|weeks?|months?)) ago' | head -1)
    # Output: session_id|directory|timestamp|summary
    echo "${thread_id}|$(pwd)|${updated:-unknown}|${title}"
  done
}

cmd_resume() {
  local custom_name="${1:-}"

  # Determine configured tool
  local tool=""
  if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
    tool="${LLMUX_TOOL:-}"
  fi

  if [[ -z "$tool" ]]; then
    echo "No tool configured. Run 'llmux setup' first."
    exit 1
  fi

  # Harvest sessions based on tool
  local sessions=()
  local session_ids=()
  local session_dirs=()
  local idx=1

  echo "Fetching past $tool sessions..."
  echo ""

  case "$tool" in
    claude)
      while IFS='|' read -r sid dir ts summary; do
        [[ -z "$sid" ]] && continue
        sessions+=("$sid|$dir|$ts|$summary")
        session_ids+=("$sid")
        session_dirs+=("$dir")
        printf "  %2d) [%s] %s\n" "$idx" "$ts" "$summary"
        printf "      %s @ %s\n" "$sid" "$dir"
        ((idx++))
      done < <(harvest_claude_sessions)
      ;;
    amp)
      while IFS='|' read -r sid dir ts summary; do
        [[ -z "$sid" ]] && continue
        sessions+=("$sid|$dir|$ts|$summary")
        session_ids+=("$sid")
        session_dirs+=("$dir")
        printf "  %2d) [%s] %s\n" "$idx" "${ts:-?}" "$summary"
        printf "      %s\n" "$sid"
        ((idx++))
      done < <(harvest_amp_sessions)
      ;;
    *)
      echo "Resume not supported for '$tool' yet."
      echo "Supported: claude, amp"
      exit 1
      ;;
  esac

  if [[ ${#sessions[@]} -eq 0 ]]; then
    echo "  No past sessions found."
    exit 0
  fi

  echo ""
  local choice
  read -rp "Select session to resume [1]: " choice
  choice="${choice:-1}"

  if [[ "$choice" -lt 1 || "$choice" -gt ${#sessions[@]} ]]; then
    echo "Invalid choice"
    exit 1
  fi

  local selected_id="${session_ids[$((choice - 1))]}"
  local selected_dir="${session_dirs[$((choice - 1))]}"

  # Build the resume command
  local resume_cmd=""
  local tool_args="${LLMUX_TOOL_ARGS:-}"
  case "$tool" in
    claude) resume_cmd="$tool${tool_args:+ $tool_args} --resume $selected_id" ;;
    amp)    resume_cmd="$tool${tool_args:+ $tool_args} --continue $selected_id" ;;
  esac

  # Derive pane name
  local pane_name="$custom_name"
  if [[ -z "$pane_name" ]]; then
    # Use the summary as the pane name, truncated
    local summary
    summary=$(echo "${sessions[$((choice - 1))]}" | cut -d'|' -f4)
    pane_name="${summary:0:40}"
    [[ -z "$pane_name" ]] && pane_name="$selected_id"
  fi

  # Create the pane (reuse add logic but with custom launch)
  ensure_session

  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    local first_title
    first_title=$(tmux list-panes -t "$SESSION" -F '#{pane_title}' | head -1)
    if [[ -z "$first_title" || "$first_title" == "bash" || "$first_title" == "zsh" ]]; then
      tmux send-keys -t "$SESSION" "cd '$selected_dir'" Enter
      tmux select-pane -t "$SESSION" -T "$pane_name"
      tmux send-keys -t "$SESSION" "clear" Enter
      tmux send-keys -t "$SESSION" "unset CLAUDECODE CLAUDE_CODE_SESSION; $resume_cmd" Enter
      echo "Resuming '$selected_id' as '$pane_name'"
      return
    fi
  fi

  tmux split-window -t "$SESSION" -c "$selected_dir"
  tmux select-pane -t "$SESSION" -T "$pane_name"
  tmux select-layout -t "$SESSION" tiled
  tmux send-keys -t "$SESSION" "unset CLAUDECODE CLAUDE_CODE_SESSION; $resume_cmd" Enter
  echo "Resuming '$selected_id' as '$pane_name'"
}

cmd_grab() {
  local name="${1:?Usage: llmux grab <name> [source-pane]}"
  local source="${2:-}"

  ensure_session

  # Check if a pane with this name already exists
  if tmux list-panes -t "$SESSION" -F '#{pane_title}' 2>/dev/null | grep -qxF "$name"; then
    echo "Error: pane '$name' already exists"
    exit 1
  fi

  # If no source given, show available panes to pick from
  if [[ -z "$source" ]]; then
    echo "Available tmux panes (excluding llmux):"
    echo ""
    local panes=()
    local idx=1
    while IFS= read -r line; do
      local pane_target pane_title pane_cmd pane_path
      pane_target=$(echo "$line" | cut -d'|' -f1)
      pane_title=$(echo "$line" | cut -d'|' -f2)
      pane_cmd=$(echo "$line" | cut -d'|' -f3)
      pane_path=$(echo "$line" | cut -d'|' -f4)
      # Skip panes in the llmux session
      [[ "$pane_target" == "$SESSION:"* ]] && continue
      panes+=("$pane_target")
      printf "  %d) %s  [%s]  (%s)\n" "$idx" "$pane_target" "$pane_cmd" "$pane_path"
      ((idx++))
    done < <(tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}|#{pane_title}|#{pane_current_command}|#{pane_current_path}')

    if [[ ${#panes[@]} -eq 0 ]]; then
      echo "  No other panes found."
      exit 0
    fi

    echo ""
    local choice
    read -rp "Select pane to grab [1]: " choice
    choice="${choice:-1}"
    if [[ "$choice" -lt 1 || "$choice" -gt ${#panes[@]} ]]; then
      echo "Invalid choice"
      exit 1
    fi
    source="${panes[$((choice - 1))]}"
  fi

  # Check if the llmux session has only the default empty pane
  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    local first_title
    first_title=$(tmux list-panes -t "$SESSION" -F '#{pane_title}' | head -1)
    if [[ -z "$first_title" || "$first_title" == "bash" || "$first_title" == "zsh" ]]; then
      # Swap the empty initial pane with the source
      local empty_pane
      empty_pane=$(tmux list-panes -t "$SESSION" -F '#{pane_id}' | head -1)
      tmux join-pane -s "$source" -t "$SESSION"
      tmux kill-pane -t "$empty_pane"
      tmux select-pane -t "$SESSION" -T "$name"
      echo "Grabbed pane '$source' as '$name'"
      return
    fi
  fi

  # Join the source pane into llmux
  tmux join-pane -s "$source" -t "$SESSION"
  tmux select-pane -t "$SESSION" -T "$name"
  tmux select-layout -t "$SESSION" tiled
  echo "Grabbed pane '$source' as '$name'"
}

# --- Main ---
command="${1:-help}"
shift || true

case "$command" in
  add)    cmd_add "$@" ;;
  resume) cmd_resume "$@" ;;
  grab)   cmd_grab "$@" ;;
  rm)     cmd_rm "$@" ;;
  ls)     cmd_ls "$@" ;;
  attach) cmd_attach "$@" ;;
  setup)  cmd_setup "$@" ;;
  help)   usage ;;
  *)      echo "Unknown command: $command"; usage; exit 1 ;;
esac

#!/usr/bin/env bash
set -euo pipefail

SESSION="llmux"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/llmux"
CONFIG_FILE="$CONFIG_DIR/config"

usage() {
  cat <<EOF
llmux — multiplex LLM sessions in tmux

Usage:
  llmux add <name> [directory] [--tool <tool>]  Add a new pane (default tool from config)
  llmux resume [--tool <tool>]                  Pick a past session to resume
  llmux grab <name> [pane]                      Move an existing tmux pane into llmux
  llmux rm <name>                               Remove pane by name
  llmux ls                                      List active panes
  llmux attach                                  Attach to the llmux session
  llmux setup                                   Install deps + configure LLM tools
  llmux help                                    Show this help

Examples:
  llmux add "auth-refactor" ~/code/myproject
  llmux add "bug-hunt" --tool amp
  llmux resume                                  # resume with default tool
  llmux resume --tool claude                    # resume a claude session specifically
  llmux grab "ongoing-debug"
  llmux rm "auth-refactor"
EOF
}

check_deps() {
  local missing=()
  for dep in gum tmux python3; do
    command -v "$dep" &>/dev/null || missing+=("$dep")
  done
  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Missing dependencies: ${missing[*]}"
    echo "Run 'llmux setup' to install them."
    exit 1
  fi
}

KNOWN_TOOLS=(amp claude aider sgpt llm mods ollama)

load_config() {
  LLMUX_TOOL=""
  LLMUX_TOOL_ARGS=""
  if [[ -f "$CONFIG_FILE" ]]; then
    source "$CONFIG_FILE"
  fi
}

get_tool_args() {
  local tool="$1"
  load_config
  local upper
  upper=$(echo "$tool" | tr '[:lower:]-' '[:upper:]_')
  local var="LLMUX_ARGS_${upper}"
  local args
  eval "args=\${$var:-}"
  if [[ -z "$args" && "$tool" == "${LLMUX_TOOL:-}" ]]; then
    args="${LLMUX_TOOL_ARGS:-}"
  fi
  echo "$args"
}

build_tool_cmd() {
  local tool="$1"
  local args
  args="$(get_tool_args "$tool")"
  echo "$tool${args:+ $args}"
}

launch_tool_in_pane() {
  local pane_target="$1"
  local tool="${2:-}"

  if [[ -z "$tool" ]]; then
    load_config
    tool="${LLMUX_TOOL:-}"
  fi

  if [[ -n "$tool" ]]; then
    local tool_cmd
    tool_cmd="$(build_tool_cmd "$tool")"
    tmux send-keys -t "$pane_target" "unset CLAUDECODE CLAUDE_CODE_SESSION; $tool_cmd" Enter
  fi
}

ensure_session() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    tmux new-session -d -s "$SESSION" -x - -y -
    # Enable pane titles in the border
    tmux set-option -t "$SESSION" pane-border-status top
    tmux set-option -t "$SESSION" pane-border-format ' #{pane_title} [#{pane_current_path}] '
    # Style the borders for clarity
    tmux set-option -t "$SESSION" pane-border-style 'fg=colour240'
    tmux set-option -t "$SESSION" pane-active-border-style 'fg=colour39,bold'
    # Kill the initial empty pane marker — we'll track it
    INITIAL_PANE=1
  fi
}

cmd_add() {
  local name="" dir="" tool_override=""

  # Parse args: name [directory] [--tool <tool>]
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tool) tool_override="${2:?--tool requires a value}"; shift 2 ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
        elif [[ -z "$dir" ]]; then
          dir="$1"
        fi
        shift
        ;;
    esac
  done

  [[ -z "$name" ]] && { echo "Usage: llmux add <name> [directory] [--tool <tool>]"; exit 1; }
  dir="${dir:-$(pwd)}"
  dir="$(cd "$dir" && pwd)"

  ensure_session

  if tmux list-panes -t "$SESSION" -F '#{pane_title}' 2>/dev/null | grep -qxF "$name"; then
    echo "Error: pane '$name' already exists"
    exit 1
  fi

  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    local first_title
    first_title=$(tmux list-panes -t "$SESSION" -F '#{pane_title}' | head -1)
    if [[ -z "$first_title" || "$first_title" == "bash" || "$first_title" == "zsh" ]]; then
      tmux send-keys -t "$SESSION" "cd '$dir'" Enter
      tmux select-pane -t "$SESSION" -T "$name"
      tmux send-keys -t "$SESSION" "clear" Enter
      launch_tool_in_pane "$SESSION" "$tool_override"
      echo "Created pane '$name' in $dir"
      return
    fi
  fi

  tmux split-window -t "$SESSION" -c "$dir"
  tmux select-pane -t "$SESSION" -T "$name"
  tmux select-layout -t "$SESSION" tiled
  launch_tool_in_pane "$SESSION" "$tool_override"
  echo "Created pane '$name' in $dir"
}

cmd_rm() {
  local name="${1:?Usage: llmux rm <name>}"

  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "Error: no llmux session running"
    exit 1
  fi

  # Find the pane with this title
  local target_pane=""
  while IFS= read -r line; do
    local pane_id pane_title
    pane_id=$(echo "$line" | cut -d'|' -f1)
    pane_title=$(echo "$line" | cut -d'|' -f2)
    if [[ "$pane_title" == "$name" ]]; then
      target_pane="$pane_id"
      break
    fi
  done < <(tmux list-panes -t "$SESSION" -F '#{pane_id}|#{pane_title}')

  if [[ -z "$target_pane" ]]; then
    echo "Error: no pane named '$name'"
    exit 1
  fi

  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    # Last pane — kill the whole session
    tmux kill-session -t "$SESSION"
    echo "Removed pane '$name' (session ended)"
  else
    tmux kill-pane -t "$target_pane"
    tmux select-layout -t "$SESSION" tiled
    echo "Removed pane '$name'"
  fi
}

cmd_ls() {
  if ! tmux has-session -t "$SESSION" 2>/dev/null; then
    echo "No llmux session running"
    exit 0
  fi

  printf "%-4s  %-30s  %s\n" "IDX" "NAME" "DIRECTORY"
  printf "%-4s  %-30s  %s\n" "---" "----" "---------"
  local idx=0
  while IFS= read -r line; do
    local pane_title pane_path
    pane_title=$(echo "$line" | cut -d'|' -f1)
    pane_path=$(echo "$line" | cut -d'|' -f2)
    printf "%-4s  %-30s  %s\n" "$idx" "$pane_title" "$pane_path"
    ((idx++))
  done < <(tmux list-panes -t "$SESSION" -F '#{pane_title}|#{pane_current_path}')
}

cmd_attach() {
  ensure_session
  if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$SESSION"
  else
    tmux attach-session -t "$SESSION"
  fi
}

cmd_setup() {
  # --- Install dependencies ---
  local deps=(gum tmux python3)
  local missing=()
  for dep in "${deps[@]}"; do
    command -v "$dep" &>/dev/null || missing+=("$dep")
  done

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Installing missing dependencies: ${missing[*]}"
    if command -v brew &>/dev/null; then
      local brew_pkgs=()
      for dep in "${missing[@]}"; do
        case "$dep" in
          python3) brew_pkgs+=("python") ;;
          *)       brew_pkgs+=("$dep") ;;
        esac
      done
      brew install "${brew_pkgs[@]}"
    else
      echo "Error: Homebrew not found. Install manually: ${missing[*]}"
      exit 1
    fi
    echo ""
  fi

  echo "✓ All dependencies installed"
  echo ""

  # --- Find available LLM tools ---
  local found_tools=()
  for tool in "${KNOWN_TOOLS[@]}"; do
    command -v "$tool" &>/dev/null && found_tools+=("$tool")
  done

  if [[ ${#found_tools[@]} -eq 0 ]]; then
    echo "No known LLM tools found on PATH."
    exit 0
  fi

  # --- Pick default tool ---
  local selected
  selected=$(printf '%s\n' "(none)" "${found_tools[@]}" | gum choose --header "Select DEFAULT LLM tool")
  [[ "$selected" == "(none)" ]] && selected=""

  # --- Configure args for each found tool ---
  mkdir -p "$CONFIG_DIR"
  cat > "$CONFIG_FILE" <<CONF
LLMUX_TOOL="$selected"
CONF

  echo ""
  for tool in "${found_tools[@]}"; do
    local args
    args=$(gum input --placeholder "e.g. --dangerously-skip-permissions" --header "Startup args for $tool (enter to skip)")
    local upper
    upper=$(echo "$tool" | tr '[:lower:]-' '[:upper:]_')
    echo "LLMUX_ARGS_${upper}=\"${args}\"" >> "$CONFIG_FILE"
    if [[ -n "$args" ]]; then
      echo "  $tool: $args"
    else
      echo "  $tool: (no args)"
    fi
  done

  echo ""
  if [[ -n "$selected" ]]; then
    echo "✓ Default tool: $selected"
  else
    echo "✓ No default tool (shell only)"
  fi
  echo "  Saved to $CONFIG_FILE"
}

harvest_claude_sessions() {
  python3 << 'PYEOF'
import json, os, glob, time

def relative_time(mtime):
    delta = int(time.time() - mtime)
    if delta < 60:
        return f"{delta}s ago"
    elif delta < 3600:
        return f"{delta // 60}m ago"
    elif delta < 86400:
        return f"{delta // 3600}h ago"
    else:
        days = delta // 86400
        return f"{days}d ago"

def decode_project_path(encoded):
    """Decode Claude's project dir encoding by finding the real path on disk.
    Tries /, ., and - as separators with backtracking to find a valid path."""
    parts = encoded.lstrip("-").split("-")

    def resolve(idx, current):
        if idx == len(parts):
            return current
        part = parts[idx]
        seps = ["/"] if not current else ["/", ".", "-"]
        for sep in seps:
            candidate = current + sep + part
            result = resolve(idx + 1, candidate)
            if result and os.path.exists(result):
                return result
        return current + "/" + part if idx == len(parts) - 1 else None

    result = resolve(0, "")
    return result if result and os.path.exists(result) else "/" + "/".join(parts)

projects_dir = os.path.expanduser("~/.claude/projects")
if not os.path.isdir(projects_dir):
    exit(0)

home = os.path.expanduser("~")
for jsonl in sorted(glob.glob(f"{projects_dir}/*/*.jsonl"), key=os.path.getmtime, reverse=True)[:20]:
    project = os.path.basename(os.path.dirname(jsonl))
    session_id = os.path.basename(jsonl).replace(".jsonl", "")
    mtime = os.path.getmtime(jsonl)

    proj_path = decode_project_path(project)

    # Find first real user message as summary
    summary = ""
    with open(jsonl) as f:
        for line in f:
            try:
                msg = json.loads(line.strip())
                if msg.get("type") != "user":
                    continue
                content = msg.get("message", {}).get("content", "")
                if isinstance(content, str):
                    text = content
                elif isinstance(content, list):
                    text = next((b["text"] for b in content if isinstance(b, dict) and b.get("type") == "text"), "")
                else:
                    continue
                if text and not text.startswith("<local-command") and not text.startswith("<command-name>"):
                    summary = text[:80].replace("\n", " ").strip()
                    break
            except:
                pass

    ts = relative_time(mtime)
    # Output pipe-delimited: session_id|project_path|timestamp|summary
    print(f"{session_id}|{proj_path}|{ts}|{summary or '(empty session)'}")
PYEOF
}

harvest_amp_sessions() {
  amp threads list 2>/dev/null | tail -n +3 | while IFS= read -r line; do
    # Parse the table output: Title, Last Updated, Visibility, Messages, Thread ID
    # The format is column-aligned, thread ID is the last field
    local thread_id title updated
    thread_id=$(echo "$line" | grep -oE 'T-[0-9a-f-]+' | head -1)
    [[ -z "$thread_id" ]] && continue
    # Extract title (everything before the first date-like pattern or time-ago)
    title=$(echo "$line" | sed -E 's/[[:space:]]+(([0-9]+[smhd]|[0-9]+ (seconds?|minutes?|hours?|days?|weeks?|months?)) ago|[0-9]{4}-[0-9]{2}-[0-9]{2}).*//' | sed 's/[[:space:]]*$//')
    updated=$(echo "$line" | grep -oE '([0-9]+[smhd]|[0-9]+ (seconds?|minutes?|hours?|days?|weeks?|months?)) ago' | head -1)
    # Output: session_id|directory|timestamp|summary
    echo "${thread_id}|$(pwd)|${updated:-unknown}|${title}"
  done
}

cmd_resume() {
  local tool_override=""

  # Parse args: [--tool <tool>]
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --tool) tool_override="${2:?--tool requires a value}"; shift 2 ;;
      *) shift ;;
    esac
  done

  # Determine which tool to browse
  local tool="$tool_override"
  if [[ -z "$tool" ]]; then
    load_config
    # Find all resumable tools on the system
    local resumable=()
    for t in claude amp; do
      command -v "$t" &>/dev/null && resumable+=("$t")
    done

    if [[ ${#resumable[@]} -eq 0 ]]; then
      echo "No resumable tools found (need claude or amp)."
      exit 1
    elif [[ ${#resumable[@]} -eq 1 ]]; then
      tool="${resumable[0]}"
    else
      tool=$(printf '%s\n' "${resumable[@]}" | gum choose --header "Which tool's sessions?")
      [[ -z "$tool" ]] && exit 0
    fi
  fi

  # Harvest sessions
  local raw_lines=()
  local display_lines=()

  case "$tool" in
    claude)
      while IFS='|' read -r sid dir ts summary; do
        [[ -z "$sid" ]] && continue
        raw_lines+=("$sid|$dir|$ts|$summary")
        local short_dir="${dir/#$HOME/~}"
        display_lines+=("$(printf '%-10s │ %-50s │ %s' "$ts" "${summary:0:50}" "$short_dir")")
      done < <(harvest_claude_sessions)
      ;;
    amp)
      while IFS='|' read -r sid dir ts summary; do
        [[ -z "$sid" ]] && continue
        raw_lines+=("$sid|$dir|$ts|$summary")
        local short_dir="${dir/#$HOME/~}"
        display_lines+=("$(printf '%-10s │ %-50s │ %s' "${ts:-?}" "${summary:0:50}" "$short_dir")")
      done < <(harvest_amp_sessions)
      ;;
    *)
      echo "Resume not supported for '$tool'. Supported: claude, amp"
      exit 1
      ;;
  esac

  if [[ ${#raw_lines[@]} -eq 0 ]]; then
    echo "No past sessions found."
    exit 0
  fi

  # Pick a session
  local selected_line
  selected_line=$(printf '%s\n' "${display_lines[@]}" | gum filter \
    --header "Resume a $tool session" \
    --indicator "▸" \
    --indicator.foreground "212" \
    --text.foreground "245" \
    --match.foreground "212" \
    --header.foreground "99" \
    --prompt.foreground "39" \
    --cursor-text.foreground "white")

  [[ -z "$selected_line" ]] && exit 0

  # Find the matching raw line
  local match_idx=-1
  for i in "${!display_lines[@]}"; do
    if [[ "${display_lines[$i]}" == "$selected_line" ]]; then
      match_idx=$i
      break
    fi
  done

  if [[ "$match_idx" -lt 0 ]]; then
    echo "Error: could not match selection"
    exit 1
  fi

  local selected_id selected_dir selected_summary
  selected_id=$(echo "${raw_lines[$match_idx]}" | cut -d'|' -f1)
  selected_dir=$(echo "${raw_lines[$match_idx]}" | cut -d'|' -f2)
  selected_summary=$(echo "${raw_lines[$match_idx]}" | cut -d'|' -f4)

  # Prompt for pane name (default to summary)
  local default_name="${selected_summary:0:40}"
  [[ -z "$default_name" ]] && default_name="$selected_id"
  local pane_name
  pane_name=$(gum input --value "$default_name" --header "Pane name")
  [[ -z "$pane_name" ]] && pane_name="$default_name"

  # Build resume command with per-tool args
  local tool_cmd
  tool_cmd="$(build_tool_cmd "$tool")"
  local resume_cmd=""
  case "$tool" in
    claude) resume_cmd="$tool_cmd --resume $selected_id" ;;
    amp)    resume_cmd="$tool_cmd --continue $selected_id" ;;
  esac

  # Create the pane and launch
  ensure_session

  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    local first_title
    first_title=$(tmux list-panes -t "$SESSION" -F '#{pane_title}' | head -1)
    if [[ -z "$first_title" || "$first_title" == "bash" || "$first_title" == "zsh" ]]; then
      tmux send-keys -t "$SESSION" "cd '$selected_dir'" Enter
      tmux select-pane -t "$SESSION" -T "$pane_name"
      tmux send-keys -t "$SESSION" "clear" Enter
      tmux send-keys -t "$SESSION" "unset CLAUDECODE CLAUDE_CODE_SESSION; $resume_cmd" Enter
      echo "✓ Resuming as '$pane_name'"
      return
    fi
  fi

  tmux split-window -t "$SESSION" -c "$selected_dir"
  tmux select-pane -t "$SESSION" -T "$pane_name"
  tmux select-layout -t "$SESSION" tiled
  tmux send-keys -t "$SESSION" "unset CLAUDECODE CLAUDE_CODE_SESSION; $resume_cmd" Enter
  echo "✓ Resuming as '$pane_name'"
}

cmd_grab() {
  local name="${1:?Usage: llmux grab <name> [source-pane]}"
  local source="${2:-}"

  ensure_session

  # Check if a pane with this name already exists
  if tmux list-panes -t "$SESSION" -F '#{pane_title}' 2>/dev/null | grep -qxF "$name"; then
    echo "Error: pane '$name' already exists"
    exit 1
  fi

  # If no source given, show available panes to pick from
  if [[ -z "$source" ]]; then
    echo "Available tmux panes (excluding llmux):"
    echo ""
    local panes=()
    local idx=1
    while IFS= read -r line; do
      local pane_target pane_title pane_cmd pane_path
      pane_target=$(echo "$line" | cut -d'|' -f1)
      pane_title=$(echo "$line" | cut -d'|' -f2)
      pane_cmd=$(echo "$line" | cut -d'|' -f3)
      pane_path=$(echo "$line" | cut -d'|' -f4)
      # Skip panes in the llmux session
      [[ "$pane_target" == "$SESSION:"* ]] && continue
      panes+=("$pane_target")
      printf "  %d) %s  [%s]  (%s)\n" "$idx" "$pane_target" "$pane_cmd" "$pane_path"
      ((idx++))
    done < <(tmux list-panes -a -F '#{session_name}:#{window_index}.#{pane_index}|#{pane_title}|#{pane_current_command}|#{pane_current_path}')

    if [[ ${#panes[@]} -eq 0 ]]; then
      echo "  No other panes found."
      exit 0
    fi

    echo ""
    local choice
    read -rp "Select pane to grab [1]: " choice
    choice="${choice:-1}"
    if [[ "$choice" -lt 1 || "$choice" -gt ${#panes[@]} ]]; then
      echo "Invalid choice"
      exit 1
    fi
    source="${panes[$((choice - 1))]}"
  fi

  # Check if the llmux session has only the default empty pane
  local pane_count
  pane_count=$(tmux list-panes -t "$SESSION" 2>/dev/null | wc -l | tr -d ' ')

  if [[ "$pane_count" -eq 1 ]]; then
    local first_title
    first_title=$(tmux list-panes -t "$SESSION" -F '#{pane_title}' | head -1)
    if [[ -z "$first_title" || "$first_title" == "bash" || "$first_title" == "zsh" ]]; then
      # Swap the empty initial pane with the source
      local empty_pane
      empty_pane=$(tmux list-panes -t "$SESSION" -F '#{pane_id}' | head -1)
      tmux join-pane -s "$source" -t "$SESSION"
      tmux kill-pane -t "$empty_pane"
      tmux select-pane -t "$SESSION" -T "$name"
      echo "Grabbed pane '$source' as '$name'"
      return
    fi
  fi

  # Join the source pane into llmux
  tmux join-pane -s "$source" -t "$SESSION"
  tmux select-pane -t "$SESSION" -T "$name"
  tmux select-layout -t "$SESSION" tiled
  echo "Grabbed pane '$source' as '$name'"
}

# --- Main ---
command="${1:-help}"
shift || true

# setup and help don't need deps; everything else does
case "$command" in
  setup|help) ;;
  *)          check_deps ;;
esac

case "$command" in
  add)    cmd_add "$@" ;;
  resume) cmd_resume "$@" ;;
  grab)   cmd_grab "$@" ;;
  rm)     cmd_rm "$@" ;;
  ls)     cmd_ls "$@" ;;
  attach) cmd_attach "$@" ;;
  setup)  cmd_setup "$@" ;;
  help)   usage ;;
  *)      echo "Unknown command: $command"; usage; exit 1 ;;
esac
